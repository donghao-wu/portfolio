---
import type { Project } from '../../data/projects';
interface Props { project: Project }
const { project } = Astro.props;
const biliLink = project.links?.find(l => l.label === "Bilibili");
---
<div class="space-y-6">
  {project.videoUrl ? (
    <div class="w-full" style="aspect-ratio: 16/9;">
      <iframe
        src={project.videoUrl}
        title="Bilibili 视频播放器"
        class="w-full h-full border-0"
        allowfullscreen
        sandbox="allow-top-navigation allow-same-origin allow-forms allow-scripts"
      />
    </div>
  ) : (
    <img src={project.cover} alt={project.coverAlt} class="w-full object-cover" />
  )}
  {biliLink && (
    <a
      href={biliLink.url}
      target="_blank"
      rel="noopener"
      class="inline-block px-6 py-2.5 border border-dark text-dark font-sans text-xs tracking-widest uppercase hover:bg-dark hover:text-cream transition-colors duration-200"
    >
      在 Bilibili 观看 →
    </a>
  )}
</div>
