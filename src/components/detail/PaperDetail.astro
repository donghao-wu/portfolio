---
import type { Project } from '../../data/projects';
interface Props { project: Project }
const { project } = Astro.props;
---
<div class="space-y-8 font-sans text-sm">
  {project.publication && (
    <p class="text-muted">
      <span class="uppercase tracking-widest text-xs block mb-1">发表于</span>
      <span class="text-dark text-base">{project.publication}</span>
    </p>
  )}
  {project.authors && project.authors.length > 0 && (
    <p class="text-muted">
      <span class="uppercase tracking-widest text-xs block mb-1">作者</span>
      <span class="text-dark">{project.authors.join(" · ")}</span>
    </p>
  )}
  {project.abstract && (
    <div>
      <span class="uppercase tracking-widest text-xs text-muted block mb-2">摘要</span>
      <p class="text-dark leading-relaxed">{project.abstract}</p>
    </div>
  )}
  <div class="flex flex-wrap gap-3 pt-2">
    {project.pdfUrl && (
      <a
        href={project.pdfUrl}
        target="_blank"
        rel="noopener"
        download
        class="inline-block px-6 py-2.5 border border-dark text-dark font-sans text-xs tracking-widest uppercase hover:bg-dark hover:text-cream transition-colors duration-200"
      >
        PDF 下载 →
      </a>
    )}
    {project.links?.map(link => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-2.5 border border-muted text-muted font-sans text-xs tracking-widest uppercase hover:border-dark hover:text-dark transition-colors duration-200"
      >
        {link.label} →
      </a>
    ))}
  </div>
</div>
