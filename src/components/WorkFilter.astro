---
import type { Room } from '../data/projects';
import { ROOM_LABELS } from '../data/projects';

const roomList: Room[] = [
  'ROOM 01',
  'ROOM 02',
  'ROOM 03',
  'ROOM 04',
  'ROOM 05',
  'ROOM 06',
];
---
<div class="flex flex-wrap gap-2 mb-10" id="filter-tabs">
  <button
    type="button"
    data-filter="all"
    class="px-4 py-1.5 font-sans text-xs tracking-widest border transition-colors duration-200 border-dark bg-dark text-cream"
  >
    全部
  </button>
  {roomList.map((room) => (
    <button
      type="button"
      data-filter={room}
      class="px-4 py-1.5 font-sans text-xs tracking-widest border transition-colors duration-200 border-border text-muted hover:border-dark hover:text-dark"
    >
      {ROOM_LABELS[room]}
    </button>
  ))}
</div>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('#filter-tabs button');
  const cards = document.querySelectorAll<HTMLElement>('[data-room]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter!;

      tabs.forEach((t) => {
        t.classList.remove('border-dark', 'bg-dark', 'text-cream');
        t.classList.add('border-border', 'text-muted');
      });
      tab.classList.add('border-dark', 'bg-dark', 'text-cream');
      tab.classList.remove('border-border', 'text-muted');

      cards.forEach((card) => {
        if (filter === 'all' || card.dataset.room === filter) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });

      // 同步 URL，让详情页返回时能回到当前 tab
      const url = new URL(window.location.href);
      if (filter === 'all') {
        url.searchParams.delete('room');
      } else {
        url.searchParams.set('room', filter.replace('ROOM ', ''));
      }
      history.replaceState(null, '', url.toString());
    });
  });

  // URL 参数用短编号 (01–06)，映射回完整 room 名称
  const params = new URLSearchParams(window.location.search);
  const roomParam = params.get('room');
  if (roomParam) {
    const fullRoom = roomParam.startsWith('ROOM') ? roomParam : `ROOM ${roomParam}`;
    const matchingTab = [...tabs].find((t) => t.dataset.filter === fullRoom);
    if (matchingTab) matchingTab.click();
  }
</script>
