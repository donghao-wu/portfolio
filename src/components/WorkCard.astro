---
import { roomTitle, type Project } from '../data/projects';
import { withBase } from '../lib/site';

interface Props {
  project: Project;
}
const { project } = Astro.props;
---
<a
  href={withBase(`/works/${project.slug}`)}
  class="group block relative overflow-hidden hover:border-dark transition-colors duration-300"
  data-room={project.room}
>
  <!-- Cover image -->
  <div class="aspect-[4/3] relative overflow-hidden bg-gray-100">
    <img
      src={withBase(project.cover)}
      alt={project.coverAlt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <!-- Year -->
    <span class="absolute bottom-2 right-3 font-serif text-5xl font-extralight text-white opacity-20 leading-none select-none pointer-events-none">
      {project.year}
    </span>
  </div>

  <!-- Card info -->
  <div class="p-4 bg-cream border-t border-border">
    <p class="font-sans text-[10px] tracking-[0.3em] uppercase text-accent mb-1">{roomTitle(project.room)}</p>
    <p class="font-serif text-lg text-dark leading-snug group-hover:opacity-70 transition-opacity">{project.title}</p>
  </div>
</a>
