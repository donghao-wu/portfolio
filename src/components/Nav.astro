---
const currentPath = Astro.url.pathname;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-cream border-b border-border">
  <div class="flex items-center justify-between px-8 py-5">
    <a href="/" class="font-serif text-lg tracking-widest uppercase text-dark hover:opacity-60 transition-opacity">
      你的名字
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex gap-8 font-sans text-sm tracking-wider uppercase text-muted">
      <a href="/works" class:list={["hover:text-dark transition-colors", { "text-dark": currentPath.startsWith("/works") }]}>
        作品
      </a>
      <a href="/about" class:list={["hover:text-dark transition-colors", { "text-dark": currentPath === "/about" }]}>
        关于
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button id="nav-toggle" class="md:hidden flex flex-col gap-1.5 p-1" aria-label="Menu">
      <span class="block w-5 h-px bg-dark transition-transform duration-200" id="bar1"></span>
      <span class="block w-5 h-px bg-dark transition-opacity duration-200" id="bar2"></span>
      <span class="block w-5 h-px bg-dark transition-transform duration-200" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="nav-drawer" class="hidden md:hidden border-t border-border px-8 py-6 flex flex-col gap-5 font-sans text-sm tracking-wider uppercase text-muted">
    <a href="/works" class="hover:text-dark transition-colors">作品</a>
    <a href="/about" class="hover:text-dark transition-colors">关于</a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const drawer = document.getElementById('nav-drawer')!;
  toggle.addEventListener('click', () => {
    drawer.classList.toggle('hidden');
  });
</script>
