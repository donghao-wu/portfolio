---
import BaseLayout from '../layouts/BaseLayout.astro';
import RoomCard from '../components/RoomCard.astro';
import type { Room } from '../data/projects';

const rooms: { room: Room; cover: string; coverAlt: string }[] = [
  { room: "ROOM 01", cover: "/images/room-01.png", coverAlt: "room-01" },
  { room: "ROOM 02", cover: "/images/room-02.png", coverAlt: "room-02" },
  { room: "ROOM 03", cover: "/images/room-03.png", coverAlt: "room-03" },
  { room: "ROOM 04", cover: "/images/room-04.png", coverAlt: "room-04" },
  { room: "ROOM 05", cover: "/images/room-05.webp", coverAlt: "room-05" },
  { room: "ROOM 06", cover: "/images/room-06.jpg", coverAlt: "room-06" },
];
---
<BaseLayout title="首页">
  <!-- Hero -->
  <section class="px-8 pt-20 pb-16 max-w-5xl mx-auto">
    <h1 class="font-serif text-6xl sm:text-8xl font-light text-dark leading-none mb-4">
      Lucius 吴东昊
    </h1>
    <p class="font-sans text-base text-muted tracking-wide">
      AIGC Creator · Developer · Researcher · AIGC 创作者 · 软件开发者 · 研究学者
    </p>
  </section>

  <!-- Room divider -->
  <div class="px-8 max-w-5xl mx-auto border-t border-border mb-28">
    <p class="font-sans text-sm sm:text-base tracking-[0.3em] uppercase text-muted pt-4">展厅</p>
  </div>

  <!-- Room grid -->
  <section class="px-8 pb-12 max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-px bg-border border border-border">
    {rooms.map(({ room, cover, coverAlt }) => (
      <RoomCard
        room={room}
        cover={cover}
        coverAlt={coverAlt}
        href={`/works?room=${encodeURIComponent(room)}`}
      />
    ))}
  </section>
</BaseLayout>
