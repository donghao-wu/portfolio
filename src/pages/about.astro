---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
---
<BaseLayout title="关于" description="关于我">
  <div class="px-8 pt-12 pb-24 max-w-3xl mx-auto">

    <!-- Page header -->
    <div class="mb-16">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-gray-300 mb-6">About — 关于</p>
      <h1 class="font-serif text-5xl sm:text-6xl font-light text-dark leading-none mb-0">关于</h1>
    </div>

    <!-- Bio -->
    <section class="mb-16">
      <div class="border-t-2 border-accent pt-3 mb-8">
        <span class="font-sans text-[9px] tracking-[0.6em] uppercase text-accent">Biography</span>
      </div>
      <div class="space-y-5 font-sans text-sm text-gray-600 leading-relaxed">
        <p>
          我在西方学院（Occidental College）取得心理学学士学位，随后就读于芝加哥大学社会科学硕士项目，专注计算社会科学方向，曾以机器学习方法研究人类与 AI 的对话差异。学术训练让我习惯用数据思考问题，也让我对人的行为与叙事有持续的好奇。
        </p>
        <p>
          毕业后加入 Onefilms 担任 AI 产品经理，主导 AIGC 内容工作流的设计与落地——从工具评测、智能体开发到漫剧批量生产，探索如何让创意在 AI 的加持下规模化呈现。这份工作让我意识到，技术本身不是目的，如何用它讲出好故事才是。
        </p>
        <p>
          这个作品集是我的创作档案，收录了 AIGC 账号运营、短片制作、软件开发、学术论文、校企项目与传统影视制作等不同方向的探索。它们共享同一个出发点：对内容本身的认真。
        </p>
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-16">
      <div class="border-t-2 border-accent pt-3 mb-8">
        <span class="font-sans text-[9px] tracking-[0.6em] uppercase text-accent">Skills</span>
      </div>
      <ul class="grid grid-cols-2 gap-y-3 font-sans text-sm text-dark">
        <li class="flex items-center gap-2"><span class="w-1 h-1 bg-accent rounded-full shrink-0"></span>AIGC 创作</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 bg-accent rounded-full shrink-0"></span>Python / Web 开发</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 bg-accent rounded-full shrink-0"></span>自然语言处理</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 bg-accent rounded-full shrink-0"></span>视频制作</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 bg-accent rounded-full shrink-0"></span>数据分析</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 bg-accent rounded-full shrink-0"></span>团队管理</li>
      </ul>
    </section>

    <!-- Contact -->
    <section class="mb-16">
      <div class="border-t-2 border-accent pt-3 mb-8">
        <span class="font-sans text-[9px] tracking-[0.6em] uppercase text-accent">Contact</span>
      </div>
      <div class="flex flex-col gap-4 font-sans text-sm">
        <a href="mailto:Luciuswu2001@outlook.com" class="group flex items-center gap-3 text-dark hover:text-accent transition-colors duration-200">
          <span class="w-8 font-sans text-[10px] tracking-widest text-muted">Mail</span>
          <span class="group-hover:underline underline-offset-4">Luciuswu2001@outlook.com</span>
        </a>
        <a href="https://github.com/donghao-wu" target="_blank" rel="noopener" class="group flex items-center gap-3 text-dark hover:text-accent transition-colors duration-200">
          <span class="w-8 font-sans text-[10px] tracking-widest text-muted">Git</span>
          <span class="group-hover:underline underline-offset-4">github.com/donghao-wu</span>
        </a>
      </div>
    </section>

    <!-- CV -->
    <section>
      <div class="border-t-2 border-accent pt-3 mb-8">
        <span class="font-sans text-[9px] tracking-[0.6em] uppercase text-accent">Resume</span>
      </div>
      <a
        href={withBase('/DW_Resume_CN.pdf')}
        download
        target="_blank"
        class="inline-flex items-center gap-3 px-6 py-3 border border-dark text-dark font-sans text-xs tracking-widest uppercase hover:bg-dark hover:text-cream transition-colors duration-200"
      >
        下载 CV (PDF) →
      </a>
    </section>

  </div>
</BaseLayout>
