---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
---
<BaseLayout title="关于" description="关于我">
  <div class="px-8 pt-12 pb-20 max-w-3xl mx-auto">

    <!-- Page header -->
    <div class="border-b border-border pb-8 mb-12">
      <h1 class="font-serif text-5xl font-light text-dark mb-2">关于</h1>
      <p class="font-sans text-sm text-muted tracking-wide">About</p>
    </div>

    <!-- Bio -->
    <section class="mb-14 space-y-5 font-sans text-base text-dark leading-relaxed">
      <p>
        我在西方学院（Occidental College）取得心理学学士学位，随后就读于芝加哥大学社会科学硕士项目，专注计算社会科学方向，曾以机器学习方法研究人类与 AI 的对话差异。学术训练让我习惯用数据思考问题，也让我对人的行为与叙事有持续的好奇。
      </p>
      <p>
        毕业后加入 Onefilms 担任 AI 产品经理，主导 AIGC 内容工作流的设计与落地——从工具评测、智能体开发到漫剧批量生产，探索如何让创意在 AI 的加持下规模化呈现。这份工作让我意识到，技术本身不是目的，如何用它讲出好故事才是。
      </p>
      <p>
        这个作品集是我的创作档案，收录了 AIGC 账号运营、短片制作、软件开发、学术论文、校企项目与传统影视制作等不同方向的探索。它们共享同一个出发点：对内容本身的认真。
      </p>
    </section>

    <!-- Skills -->
    <section class="mb-14">
      <h2 class="font-sans text-xs tracking-[0.3em] uppercase text-muted border-t border-border pt-6 mb-6">技能与方向</h2>
      <ul class="grid grid-cols-2 gap-2 font-sans text-sm text-dark">
        <li>AIGC 创作</li>
        <li>Python / Web 开发</li>
        <li>自然语言处理</li>
        <li>视频制作</li>
      </ul>
    </section>

    <!-- Contact -->
    <section class="mb-14">
      <h2 class="font-sans text-xs tracking-[0.3em] uppercase text-muted border-t border-border pt-6 mb-6">联系方式</h2>
      <div class="flex flex-col gap-3 font-sans text-sm">
        <a href="mailto:Luciuswu2001@outlook.com" class="text-dark hover:opacity-60 transition-opacity">
          📧 Luciuswu2001@outlook.com
        </a>
        <a href="https://github.com/donghao-wu" target="_blank" rel="noopener" class="text-dark hover:opacity-60 transition-opacity">
          GitHub →
        </a>
      </div>
    </section>

    <!-- CV download -->
    <section>
      <h2 class="font-sans text-xs tracking-[0.3em] uppercase text-muted border-t border-border pt-6 mb-6">简历</h2>
      <a
        href={withBase('/DW_Resume_CN.pdf')}
        download
        target="_blank"
        class="inline-block px-6 py-2.5 border border-dark text-dark font-sans text-xs tracking-widest uppercase hover:bg-dark hover:text-cream transition-colors duration-200"
      >
        下载 CV (PDF) →
      </a>
    </section>

  </div>
</BaseLayout>
